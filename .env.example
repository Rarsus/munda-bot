# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here

# Database Configuration
DATABASE_URL=postgresql://botuser:botpassword@localhost:5432/discord_bot

# Environment
NODE_ENV=development
LOG_LEVEL=debug

# Google Cloud Configuration
GCP_PROJECT_ID=your-gcp-project-id

# Cloud SQL Configuration (Cloud Run environment)
# Use format: postgresql://botuser:password@/discord_bot?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
# Or with public IP: postgresql://botuser:password@PUBLIC_IP/discord_bot
CLOUD_SQL_CONNECTION_NAME=your-project-id:europe-west4:discord-bot-db

# Optional: For debugging
DEBUG=false
SENTRY_DSN=