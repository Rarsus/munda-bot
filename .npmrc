# npm configuration for WSL/cross-platform compatibility

# Disable post-install scripts that fail in WSL
ignore-scripts=true

# Use proper platform detection
fetch-timeout=120000
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# Network settings
registry=https://registry.npmjs.org/
strict-ssl=true

# Performance settings
maxsockets=5
