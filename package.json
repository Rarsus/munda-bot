{
  "name": "discord-bot",
  "version": "1.0.0",
  "description": "TypeScript Discord Bot with PostgreSQL Backend",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "discord",
    "bot",
    "typescript",
    "postgresql"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^13.17.1",
    "dotenv": "^16.4.5",
    "pg": "^8.11.4",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.13",
    "@types/pg": "^8.11.6",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.16.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
