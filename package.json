{
  "name": "discord-bot",
  "version": "1.0.0",
  "description": "TypeScript Discord Bot with PostgreSQL Backend",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\" \"./*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\" \"./*.{json,md}\""
  },
  "keywords": [
    "discord",
    "bot",
    "typescript",
    "postgresql"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@discordjs/builders": "^1.13.1",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.5",
    "node-cron": "^4.2.1",
    "pg": "^8.11.4",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.14.13",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
